    {
      "id": "behavior-resolve-ticket",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Run resolve-identity.py with user_input 'feature/OC-1234-auth' and verify it returns type ticket with key OC-1234.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"type\": \"ticket\""
        },
        {
          "type": "output_contains",
          "value": "\"key\": \"OC-1234\""
        }
      ]
    },
    {
      "id": "behavior-resolve-url",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Run resolve-identity.py with user_input 'https://github.com/owner/repo/pull/42' and verify it returns type pr with key 42@owner-repo.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"type\": \"pr\""
        },
        {
          "type": "output_contains",
          "value": "\"key\": \"42@owner-repo\""
        }
      ]
    },
    {
      "id": "behavior-resolve-number",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Run resolve-identity.py with user_input '42' and repo 'owner/repo' and verify it returns type pr.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"type\": \"pr\""
        }
      ]
    },
    {
      "id": "behavior-resolve-needs-input",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Run resolve-identity.py with empty user_input in a non-git directory and verify it returns status needs_input.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"status\": \"needs_input\""
        }
      ]
    }
  ]
