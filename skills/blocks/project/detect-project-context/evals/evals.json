    {
      "id": "behavior-no-anchor",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "In a temporary directory with no marker directories and no git repository anywhere above it, run detect-project-context.py --start <dir> --json and verify project_root is null, marker is null, and confidence is low.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"project_root\": null"
        },
        {
          "type": "output_contains",
          "value": "\"confidence\": \"low\""
        }
      ]
    },
    {
      "id": "behavior-nested-subdir",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Create a project with .agents/skills and .agents/context, then run detect-project-context.py from a deeply nested subdirectory and verify the project root is found with marker .agents and confidence high.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"marker\": \".agents\""
        },
        {
          "type": "output_contains",
          "value": "\"confidence\": \"high\""
        }
      ]
    },
    {
      "id": "behavior-marker-priority",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Create a project with both .pi and .agents marker directories at the root. Run detect-project-context.py and verify .agents is selected by priority.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"marker\": \".agents\""
        }
      ]
    },
    {
      "id": "behavior-invalid-start",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Run detect-project-context.py with --start pointing at a non-existent path and verify it returns a status error envelope and a non-zero exit code.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"status\": \"error\""
        }
      ]
    },
    {
      "id": "behavior-vcs-ceiling",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Create a directory with .agents, and inside it a git repository (with .git) that has no marker of its own. Run detect-project-context.py from inside the repo and verify the root is the repo, marker is null, and confidence is low — the search must not escape the repo to the parent marker.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"marker\": null"
        },
        {
          "type": "output_contains",
          "value": "\"confidence\": \"low\""
        }
      ]
    },
    {
      "id": "behavior-home-cap",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Run detect-project-context.py from a stray directory whose only ancestor marker is in the user's home directory. Verify the answer is returned with confidence low and a note about the home directory, not confidence high.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"confidence\": \"low\""
        },
        {
          "type": "output_contains",
          "value": "home directory"
        }
      ]
    },
    {
      "id": "behavior-standards-resolved",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Run resolve-standards-path.py inside a project that has docs/skill-standards at its root and verify status found with the project-root source.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"status\": \"found\""
        },
        {
          "type": "output_contains",
          "value": "skill-standards"
        }
      ]
    },
    {
      "id": "behavior-standards-degraded",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Run resolve-standards-path.py with --standards-path pointing at a non-existent directory and verify status missing, degraded true, and fallback options are disclosed.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"status\": \"missing\""
        },
        {
          "type": "output_contains",
          "value": "\"degraded\": true"
        },
        {
          "type": "output_contains",
          "value": "fallback_options"
        }
      ]
    },
    {
      "id": "composition-01",
      "type": "composition",
      "prompt": "You are running first-run setup for the pr-report skill in this project. Resolve the project context first, then initialize its config, without hardcoding any paths.",
      "available_skills": [
        "detect-project-context",
        "initialize-skill",
        "token-resolver"
      ],
      "expected_selection": [
        "detect-project-context",
        "initialize-skill"
      ]
    }
  ]
