    {
      "id": "behavior-changed-files",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Run inspect-worktree.py with operation changed_files on a git repo with a branch that has changes and verify it returns a non-empty changed_files list.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"status\": \"found\""
        }
      ]
    },
    {
      "id": "behavior-inspect",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Run inspect-worktree.py with operation inspect on a git repo, with a no-op command, and verify it returns status complete with clean true.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "\"status\": \"complete\""
        }
