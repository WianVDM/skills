{
  "version": "1",
  "skill": "git-worktree-inspector",
  "tests": [
    {
      "id": "trigger-should-01",
      "type": "trigger",
      "category": "should-trigger",
      "prompt": "Check out this PR branch in a git worktree so I can inspect it.",
      "expected": "git-worktree-inspector"
    },
    {
      "id": "trigger-should-02",
      "type": "trigger",
      "category": "should-trigger",
      "prompt": "Run lint on the changed files in this PR branch without switching my current branch.",
      "expected": "git-worktree-inspector"
    },
    {
      "id": "trigger-should-03",
      "type": "trigger",
      "category": "should-trigger",
      "prompt": "Create a worktree for this branch and list the files that changed against main.",
      "expected": "git-worktree-inspector"
    },
    {
      "id": "trigger-should-04",
      "type": "trigger",
      "category": "should-trigger",
      "prompt": "I need an isolated checkout of the PR branch to run type-checks.",
      "expected": "git-worktree-inspector"
    },
    {
      "id": "trigger-should-05",
      "type": "trigger",
      "category": "should-trigger",
      "prompt": "Remove this worktree I created earlier.",
      "expected": "git-worktree-inspector"
    },
    {
      "id": "trigger-should-06",
      "type": "trigger",
      "category": "should-trigger",
      "prompt": "Inspect the PR branch in a temporary git worktree.",
      "expected": "git-worktree-inspector"
    },
    {
      "id": "trigger-should-07",
      "type": "trigger",
      "category": "should-trigger",
