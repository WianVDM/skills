    },
    {
      "id": "trigger-should-08",
      "type": "trigger",
      "category": "should-trigger",
      "prompt": "What files changed in this branch compared to main?",
      "expected": "git-worktree-inspector"
    },
    {
      "id": "trigger-should-09",
      "type": "trigger",
      "category": "should-trigger",
      "prompt": "Check out the commit in an isolated worktree.",
      "expected": "git-worktree-inspector"
    },
    {
      "id": "trigger-should-10",
      "type": "trigger",
      "category": "should-trigger",
      "prompt": "Clean up the temporary worktree after the inspection.",
      "expected": "git-worktree-inspector"
    },
