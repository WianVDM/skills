      "id": "behavior-01",
      "type": "behavior",
      "baseline_type": "no_skill",
      "prompt": "Given Jira ticket OC-1234 at my-org.atlassian.net, return the normalized issue-tracker-source shape with acceptance criteria.",
      "assertions": [
        {
          "type": "output_contains",
