{
  "name": "write-a-skill",
  "version": "1.0.1",
  "description": "Skill-design conductor for creating, reviewing, and updating skills that follow the skill standards.",
  "compatibility": {
    "harnesses": ["pi"]
  },
  "skills": ["write-a-skill"],
  "namespaces": {
    "write-a-skill": "write-a-skill:write-a-skill"
  },
  "skill_dependencies": {
