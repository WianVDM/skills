{
  "version": "1",
  "skill": "write-a-skill",
  "tests": [
    {
      "id": "behavior-change-branch-review-delegates-to-review-skill",
      "type": "behavior",
      "prompt": "Review the detect-project-context skill and tell me if it follows the standards.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "review-skill"
        },
        {
          "type": "output_contains",
          "value": "Verdict"
        },
        {
          "type": "output_contains",
          "value": "detect-project-context"
        },
        {
          "type": "output_excludes",
          "value": "I will perform the audit inline"
        }
      ]
    },
    {
      "id": "behavior-change-branch-update-produces-remediation-plan",
      "type": "behavior",
      "prompt": "Update the detect-project-context skill to align it with the latest skill standards.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "review-skill"
        },
        {
          "type": "output_contains",
          "value": "remediation plan"
        },
        {
          "type": "output_contains",
          "value": "detect-project-context"
        }
      ]
    },
    {
      "id": "behavior-standards-path-detected-from-marker",
      "type": "behavior",
      "setup": "The project has a `.agents` marker directory and the skill standards live at `.agents/docs/skill-standards/`. No `docs/skill-standards/` directory exists at the project root.",
      "prompt": "Initialize write-a-skill for this project.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": ".agents/docs/skill-standards"
        },
        {
          "type": "output_excludes",
          "value": "standards not found"
        },
        {
          "type": "output_excludes",
          "value": "degraded"
        }
      ]
    },
    {
      "id": "behavior-create-explores-overlap",
      "type": "behavior",
      "prompt": "I want to build a skill that debriefs a pull request before implementation. Walk me through the design process.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "detect-skill-overlap"
        },
        {
          "type": "output_contains",
          "value": "overlap"
        },
        {
          "type": "output_contains",
          "value": "debrief"
        }
      ]
    },
    {
      "id": "behavior-create-presents-reuse-colocate-extract",
      "type": "behavior",
      "prompt": "Design a new skill that resolves a ticket key from a branch name. Show me the alternatives and overlap analysis.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "reuse"
        },
        {
          "type": "output_contains",
          "value": "colocate"
        },
        {
          "type": "output_contains",
          "value": "extract"
        }
      ]
    },
    {
      "id": "behavior-create-writes-overlap-findings-report",
      "type": "behavior",
      "prompt": "Create a skill that helps review PRs. Before drafting, run overlap detection and write the findings to a context report.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "overlap-findings"
        }
      ]
    },
    {
      "id": "was-cl-001",
      "type": "behavior",
      "prompt": "I want a skill that gathers ticket data from the issue tracker and codebase and writes a debrief report. Walk me through the design process.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "chainlog"
        },
        {
          "type": "output_contains",
          "value": "artifact-freshness"
        },
        {
          "type": "output_contains",
          "value": "both"
        }
      ]
    },
    {
      "id": "was-cl-002",
      "type": "behavior",
      "prompt": "I want a minimal skill that reformats user input into a markdown checklist. Walk me through the design process.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "neither"
        },
        {
          "type": "output_excludes",
          "value": "chainlog"
        }
      ]
    },
    {
      "id": "was-cl-003",
      "type": "behavior",
      "prompt": "I want a skill that validates whether prior research about a ticket is still consistent with the current codebase. Walk me through the design process.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "consumer"
        },
        {
          "type": "output_contains",
          "value": "artifact-freshness"
        }
      ]
    },
    {
      "id": "was-cl-004",
      "type": "behavior",
      "prompt": "I want a skill that stores PR metadata in a private JSON file so other skills can reuse it. Walk me through the design process.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "overlap"
        },
        {
          "type": "output_contains",
          "value": "chainlog"
        }
      ]
    },
    {
      "id": "behavior-create-frontmatter-shape",
      "type": "behavior",
      "prompt": "Draft a minimal skill that reformats user input into markdown checklists.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "invocation:"
        },
        {
          "type": "output_excludes",
          "value": "version: 1."
        },
        {
          "type": "output_excludes",
          "value": "version: 2."
        }
      ]
    },
    {
      "id": "behavior-create-description-triggers",
      "type": "behavior",
      "prompt": "Design a new skill that reviews UI code for accessibility. Show me the description you would give it.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "Use when"
        },
        {
          "type": "output_contains",
          "value": "description"
        }
      ]
    },
    {
      "id": "behavior-create-type-section",
      "type": "behavior",
      "prompt": "Create a skill that validates frontmatter of other skills. Show the SKILL.md draft.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "## Type"
        }
      ]
    },
    {
      "id": "behavior-explore-writes-no-files",
      "type": "behavior",
      "prompt": "I keep renaming batches of files by hand in a messy way. Maybe there's a skill idea there, not sure.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "recommend"
        },
        {
          "type": "output_excludes",
          "value": "## SKILL.md draft"
        }
      ]
    },
    {
      "id": "behavior-change-confirms-comprehension-first",
      "type": "behavior",
      "prompt": "Review the detect-project-context skill and tell me if it follows the standards.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "output_contains",
          "value": "comprehension"
        },
        {
          "type": "output_contains",
          "value": "confirm"
        }
      ]
    }
  ]
}