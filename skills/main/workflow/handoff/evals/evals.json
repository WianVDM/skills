{
  "version": "1",
  "skill": "handoff",
  "tests": [
    {
      "id": "behavior-default-handoff",
      "type": "behavior",
      "prompt": "Write a handoff for this session.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "file_write",
          "path": ".*/handoff/unticketed\\.md"
        },
        {
          "type": "output_contains",
          "value": "handoff"
        }
      ]
    },
    {
      "id": "behavior-keyed-handoff",
      "type": "behavior",
      "prompt": "Create a handoff for ticket ABC-123.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "file_write",
          "path": ".*/handoff/abc-123\\.md"
        },
        {
          "type": "output_contains",
          "value": "abc-123"
        }
      ]
    },
    {
      "id": "behavior-quick-handoff",
      "type": "behavior",
      "prompt": "Create a quick handoff for ticket ABC-123.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "file_write",
          "path": ".*/handoff/abc-123\\.md"
        },
        {
          "type": "output_contains",
          "value": "abc-123"
        }
      ]
    },
    {
      "id": "behavior-thorough-handoff",
      "type": "behavior",
      "prompt": "Create a thorough handoff for ticket ABC-123.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "file_write",
          "path": ".*/handoff/abc-123\\.md"
        },
        {
          "type": "output_contains",
          "value": "abc-123"
        }
      ]
    },
    {
      "id": "behavior-archive-old-handoff",
      "type": "behavior",
      "prompt": "Create two handoffs for ticket ABC-123. The first should be archived when the second is written.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "file_write",
          "path": ".*/handoff/abc-123\\.md"
        },
        {
          "type": "file_write",
          "path": ".*/handoff/abc-123-\\d{8}-\\d{6}-archive\\.md"
        }
      ]
    },
    {
      "id": "behavior-context-report-frontmatter",
      "type": "behavior",
      "prompt": "Create a handoff for ticket ABC-123 and make sure it follows the context-report format.",
      "baseline_type": "no_skill",
      "assertions": [
        {
          "type": "file_contains",
          "path": ".*/handoff/abc-123\\.md",
          "value": "skill: handoff"
        },
        {
          "type": "file_contains",
          "path": ".*/handoff/abc-123\\.md",
          "value": "generated_at:"
        },
        {
          "type": "file_contains",
          "path": ".*/handoff/abc-123\\.md",
          "value": "summary:"
        }
      ]
    },
    {
      "id": "composition-conductor-checkpoints",
      "type": "composition",
      "prompt": "Checkpoint the current session for ticket ABC-123.",
      "available_skills": ["handoff", "debrief", "context-reports"],
      "expected_selection": ["handoff"]
    },
    {
      "id": "composition-no-resumption",
      "type": "composition",
      "prompt": "Continue from the latest handoff for ticket ABC-123.",
      "available_skills": ["handoff", "debrief", "context-reports"],
      "expected_selection": ["context-reports"]
    },
    {
      "id": "pressure-unwritable-context",
      "type": "pressure",
      "prompt": "Write a handoff for ticket ABC-123 while in a directory that has no writable context directory.",
      "assertions": [
        {
          "type": "output_contains",
          "value": "not writable"
        },
        {
          "type": "regex_exclude",
          "pattern": "abc-123\\.md"
        }
      ]
    }
  ]
}
